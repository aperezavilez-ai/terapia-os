# Copia este archivo a apps/web/.env.local y reemplaza con tus credenciales reales.
# NUNCA commitees .env.local ni pegues secretos reales en este archivo.

# ── Supabase (obligatorio) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── IA (obligatorio para /ia) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-tu-clave-aqui

# ── WhatsApp webhook (opcional) ──────────────────────────────
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu-token-secreto-para-verificar-webhook

# ── Cron recordatorios (opcional) ────────────────────────────
CRON_SECRET=tu-token-secreto-para-cron

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.aprendamosjuntos.mx

# ── Supabase Storage (archivos de pacientes) ─────────────────
NEXT_PUBLIC_STORAGE_BUCKET=terapia-os-files

# ── Opcional: aplicar migraciones SQL desde scripts ──────────
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
